{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ave.new webhook event",
  "description": "Fired when a new AVE card is published",
  "type": "object",
  "required": ["id", "event", "timestamp", "data"],
  "properties": {
    "id": { "type": "string", "pattern": "^evt_" },
    "event": { "const": "ave.new" },
    "timestamp": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["ave_id", "name", "category", "severity"],
      "properties": {
        "ave_id": { "type": "string", "pattern": "^AVE-\\d{4}-\\d{3,}$" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "summary": { "type": "string" },
        "date_published": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    }
  }
}
