{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ave.deprecated webhook event",
  "description": "Fired when an AVE card is deprecated",
  "type": "object",
  "required": ["id", "event", "timestamp", "data"],
  "properties": {
    "id": { "type": "string", "pattern": "^evt_" },
    "event": { "const": "ave.deprecated" },
    "timestamp": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["ave_id", "name", "reason"],
      "properties": {
        "ave_id": { "type": "string", "pattern": "^AVE-\\d{4}-\\d{3,}$" },
        "name": { "type": "string" },
        "reason": { "type": "string" },
        "superseded_by": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    }
  }
}
