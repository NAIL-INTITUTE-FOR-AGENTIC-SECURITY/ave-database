{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "advisory.published webhook event",
  "description": "Fired when a security advisory is published",
  "type": "object",
  "required": ["id", "event", "timestamp", "data"],
  "properties": {
    "id": { "type": "string", "pattern": "^evt_" },
    "event": { "const": "advisory.published" },
    "timestamp": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["advisory_id", "title", "severity", "affected_aves"],
      "properties": {
        "advisory_id": { "type": "string", "pattern": "^NAIL-SA-\\d{4}-\\d{3,}$" },
        "title": { "type": "string" },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "summary": { "type": "string" },
        "affected_aves": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mitigation": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    }
  }
}
