{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ave.updated webhook event",
  "description": "Fired when an existing AVE card is updated",
  "type": "object",
  "required": ["id", "event", "timestamp", "data"],
  "properties": {
    "id": { "type": "string", "pattern": "^evt_" },
    "event": { "const": "ave.updated" },
    "timestamp": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["ave_id", "name", "changes"],
      "properties": {
        "ave_id": { "type": "string", "pattern": "^AVE-\\d{4}-\\d{3,}$" },
        "name": { "type": "string" },
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": { "type": "string" },
              "old_value": {},
              "new_value": {}
            }
          }
        },
        "updated_by": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    }
  }
}
