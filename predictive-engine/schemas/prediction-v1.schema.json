{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schema.nailinstitute.org/prediction-v1.schema.json",
  "title": "AVE Prediction Schema v1",
  "description": "Schema for predictions generated by the NAIL Predictive Vulnerability Engine.",
  "type": "object",
  "required": [
    "prediction_id",
    "prediction_type",
    "generated_at",
    "confidence",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "prediction_id": {
      "type": "string",
      "pattern": "^pred-[a-f0-9]{10}$",
      "description": "Unique prediction identifier."
    },
    "prediction_type": {
      "type": "string",
      "enum": [
        "category_emergence",
        "severity_trend",
        "framework_risk",
        "attack_evolution",
        "defence_gap"
      ],
      "description": "The type of prediction."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the prediction was generated."
    },
    "horizon_days": {
      "type": "integer",
      "minimum": 7,
      "maximum": 365,
      "default": 90,
      "description": "Prediction time horizon in days."
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Calibrated ensemble confidence score."
    },
    "payload": {
      "type": "object",
      "description": "Prediction-type-specific payload.",
      "oneOf": [
        { "$ref": "#/definitions/category_emergence_payload" },
        { "$ref": "#/definitions/severity_trend_payload" },
        { "$ref": "#/definitions/framework_risk_payload" },
        { "$ref": "#/definitions/attack_evolution_payload" },
        { "$ref": "#/definitions/defence_gap_payload" }
      ]
    }
  },
  "definitions": {
    "category_emergence_payload": {
      "type": "object",
      "required": ["prediction_count", "predictions"],
      "properties": {
        "prediction_count": {
          "type": "integer",
          "minimum": 0
        },
        "predictions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["category", "trend", "confidence"],
            "properties": {
              "category": { "type": "string" },
              "trend": {
                "type": "string",
                "enum": ["emerging", "escalating", "increasing", "stable", "decreasing", "declining"]
              },
              "momentum": { "type": "number" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "projected_monthly_count": { "type": "integer", "minimum": 0 },
              "signal_count": { "type": "integer", "minimum": 0 },
              "is_novel": { "type": "boolean" }
            }
          }
        },
        "analysis_window_months": { "type": "integer" },
        "signals_analysed": { "type": "integer" }
      }
    },
    "severity_trend_payload": {
      "type": "object",
      "required": ["category", "current_distribution", "trend"],
      "properties": {
        "category": { "type": "string" },
        "current_distribution": {
          "type": "object",
          "properties": {
            "critical": { "type": "number" },
            "high": { "type": "number" },
            "medium": { "type": "number" },
            "low": { "type": "number" }
          }
        },
        "projected_30d": { "$ref": "#/definitions/severity_distribution" },
        "projected_60d": { "$ref": "#/definitions/severity_distribution" },
        "projected_90d": { "$ref": "#/definitions/severity_distribution" },
        "trend": { "type": "string" },
        "momentum": { "type": "number" },
        "data_points": { "type": "integer" }
      }
    },
    "severity_distribution": {
      "type": "object",
      "properties": {
        "critical": { "type": "number", "minimum": 0, "maximum": 1 },
        "high": { "type": "number", "minimum": 0, "maximum": 1 },
        "medium": { "type": "number", "minimum": 0, "maximum": 1 },
        "low": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "framework_risk_payload": {
      "type": "object",
      "required": ["framework", "current_risk_score"],
      "properties": {
        "framework": { "type": "string" },
        "current_risk_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "projected_30d_risk": { "type": "number", "minimum": 0, "maximum": 10 },
        "projected_60d_risk": { "type": "number", "minimum": 0, "maximum": 10 },
        "projected_90d_risk": { "type": "number", "minimum": 0, "maximum": 10 },
        "risk_factors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "factor": { "type": "string" },
              "weight": { "type": "number" }
            }
          }
        },
        "category_exposure": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      }
    },
    "attack_evolution_payload": {
      "type": "object",
      "required": ["categories_analysed", "evolutions"],
      "properties": {
        "categories_analysed": { "type": "integer" },
        "evolutions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["category", "trend"],
            "properties": {
              "category": { "type": "string" },
              "current_sophistication": {
                "type": "string",
                "enum": ["advanced", "moderate", "stable"]
              },
              "trend": { "type": "string" },
              "predicted_evolution": {
                "type": "object",
                "properties": {
                  "30_days": { "type": "string" },
                  "60_days": { "type": "string" },
                  "90_days": { "type": "string" }
                }
              },
              "key_drivers": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "defence_gap_payload": {
      "type": "object",
      "required": ["total_categories", "categories_with_gaps", "gaps"],
      "properties": {
        "total_categories": { "type": "integer" },
        "categories_with_gaps": { "type": "integer" },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["category", "defence_coverage", "gap_severity"],
            "properties": {
              "category": { "type": "string" },
              "threat_trend": { "type": "string" },
              "threat_momentum": { "type": "number" },
              "defence_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
              "gap_severity": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"]
              },
              "recommended_actions": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "overall_coverage": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
