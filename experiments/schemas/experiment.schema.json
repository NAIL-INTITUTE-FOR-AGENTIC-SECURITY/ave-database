{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NAIL Experiment Definition",
  "description": "Schema for NAIL Community Experiment templates",
  "type": "object",
  "required": ["id", "name", "version", "description", "category", "target_aves"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique experiment identifier"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "author": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "category": {
      "type": "string",
      "enum": ["alignment", "consensus", "credential", "delegation", "drift", "fabrication", "injection", "memory", "resource", "social", "structural", "temporal", "tool"]
    },
    "target_aves": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^AVE-\\d{4}-\\d{3}$"
      },
      "minItems": 1
    },
    "requirements": {
      "type": "object",
      "properties": {
        "models": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "min_interactions": {
          "type": "integer",
          "minimum": 1
        },
        "estimated_cost": {
          "type": "string"
        },
        "difficulty": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced", "expert"]
        }
      }
    },
    "parameters": {
      "type": "object",
      "properties": {
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "repetitions": {
          "type": "integer",
          "minimum": 1
        },
        "seed": {
          "type": "integer"
        }
      }
    },
    "criteria": {
      "type": "object",
      "properties": {
        "reproduction_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "statistical_significance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "min_samples": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "safety": {
      "type": "object",
      "properties": {
        "sandboxed": { "type": "boolean" },
        "max_cost": { "type": "number", "minimum": 0 },
        "timeout_minutes": { "type": "integer", "minimum": 1 },
        "requires_human_review": { "type": "boolean" }
      }
    }
  }
}
